// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Reception Ferraille Models

model ReceptionForm {
  id                   String            @id @default(cuid())
  ficheNumber          String?           @unique
  project              String?
  company              String?           // ENTREPRISE
  client               String?           // MAÎTRE D'ŒUVRE
  bureauEtude          String?           // BUREAU D'ÉTUDE
  block                String?           // BLOC / ZONE
  level                String?           // NIVEAU / ÉTAGE
  location             String?           // LOCALISATION (AXES)
  receptionDate        String?           // DATE DE RÉCEPTION
  receptionTime        String?           // HEURE DE RÉCEPTION
  weather              String?           // CONDITIONS MÉTÉO
  elementType          String?           // TYPE D'ÉLÉMENT
  referencePlans       String?           // PLANS DE RÉFÉRENCE
  borderau             String?           // BORDEREAU DE FERRAILLAGE
  specifications       String?           // SPÉCIFICATIONS APPLICABLES
  planNumber           String?           // N° PLAN
  planIndex            String?           // INDICE
  observations         String?           // OBSERVATIONS / RÉSERVES
  followUpAction       String?           // SUITES À DONNER
  reservationDeadline  String?           // DÉLAI ACCORDÉ POUR LEVÉE DES RÉSERVES
  reservationResponsible String?         // RESPONSABLE DE LA LEVÉE DES RÉSERVES
  status               String            @default("brouillon") // brouillon, soumis, accepté, refusé
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  verifications        VerificationItem[]
  signatures           Signature[]
  photos                Photo[]
}

model VerificationItem {
  id               String   @id @default(cuid())
  receptionFormId  String
  criteria         String   // Critère d'Acceptation
  isCompliant      Boolean? // Conforme
  isNonCompliant   Boolean? // Non Conforme
  isNotApplicable  Boolean? // N/A
  observations     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  receptionForm    ReceptionForm @relation(fields: [receptionFormId], references: [id], onDelete: Cascade)
}

model Signature {
  id              String   @id @default(cuid())
  receptionFormId String
  role            String   // ENTREPRISE, MAÎTRE D'ŒUVRE, MAÎTRE D'OUVRAGE, BUREAU DE CONTRÔLE
  name            String?
  function        String?  // Fonction
  date            String?
  time            String?
  signature       String?  // Base64 signature or signature path
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  receptionForm   ReceptionForm @relation(fields: [receptionFormId], references: [id], onDelete: Cascade)
}

model Photo {
  id              String   @id @default(cuid())
  receptionFormId String
  path            String   // File path
  index           Int      // Position (1, 2, 3, 4)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  receptionForm   ReceptionForm @relation(fields: [receptionFormId], references: [id], onDelete: Cascade)
}